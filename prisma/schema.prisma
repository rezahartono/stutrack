generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Semester {
  id         String   @id @default(cuid())
  userId     String?
  name       String
  startDate  DateTime
  endDate    DateTime
  user       User?    @relation(fields: [userId], references: [id])
  courses    Course[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Course {
  id         String   @id @default(cuid())
  semesterId String
  name       String
  code       String
  category   String   // "Praktik" | "Non-Praktik"
  day        String?  // "Senin" | "Selasa" | "Rabu" | "Kamis" | "Jumat" | "Sabtu" | "Minggu"
  startTime  String?  // Format "HH:MM"
  endTime    String?  // Format "HH:MM"
  room       String?  // Ruang kelas
  semester   Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  sessions   Session[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Session {
  id            String   @id @default(cuid())
  courseId      String
  name          String
  startDate     DateTime
  endDate       DateTime
  hasDiscussion Boolean  @default(false)
  hasTask       Boolean  @default(false)
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studyRecords  StudyRecord[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model StudyRecord {
  id         String   @id @default(cuid())
  sessionId  String
  attendance Boolean  @default(true)
  discussion Boolean  @default(false)
  task       Boolean  @default(false)
  score      Float?
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER") // "USER" or "SUPERADMIN"
  semesters Semester[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
